    "build": "vite build",
    "start": "node --env-file=.env server/index.js"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.2",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "vercel": "^50.37.3",
    "vite": "^6.3.5"
  }
}
